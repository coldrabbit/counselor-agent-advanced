      "backend": "pytest backend/ -v",
      "frontend": "cd frontend && npm run test"
    },
    "build": {
      "backend": "docker build backend/",
      "frontend": "cd frontend && npm run build"
    }
  },
  "constraints": {
    "max_auto_fix_rounds": 3,
    "max_file_lines": 300,
    "max_parallel_tasks": 3,
